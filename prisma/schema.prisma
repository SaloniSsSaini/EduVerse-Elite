// Prisma schema — PostgreSQL ready
// Set DATABASE_URL in .env to enable persistence
// Example: postgresql://user:password@localhost:5432/eduverse

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String
  program   String?
  message   String?
  source    String   @default("website")
  status    LeadStatus @default(NEW)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

model BrochureDownload {
  id        String   @id @default(cuid())
  email     String
  program   String?
  createdAt DateTime @default(now())

  @@index([email])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  ENROLLED
  CLOSED
}
